{
  "name": "3brs/sylius-mailchimp-plugin",
  "type": "sylius-plugin",
  "description": "MailChimp plugin for Sylius",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "sylius/sylius": "^2.1",
    "drewm/mailchimp-api": "^2.5.4",
    "ext-json": "*"
  },
  "require-dev": {
    "behat/behat": "^v3.24.1",
    "dbrekelmans/bdi": "^1.4",
    "friends-of-behat/mink": "^v1.11.0",
    "friends-of-behat/mink-browserkit-driver": "^v1.6.2",
    "friends-of-behat/mink-debug-extension": "^v2.1.0",
    "friends-of-behat/mink-extension": "^v2.7.5",
    "friends-of-behat/page-object-extension": "^v0.3.2",
    "friends-of-behat/suite-settings-extension": "^v1.1.0",
    "friends-of-behat/symfony-extension": "v2.6.0",
    "friends-of-behat/variadic-extension": "^v1.6.0",
    "nyholm/psr7": "^1.8",
    "phpstan/phpstan": "^2.1.10",
    "phpstan/phpstan-doctrine": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0.4",
    "phpstan/phpstan-symfony": "^2.0.3",
    "phpstan/phpstan-webmozart-assert": "^2.0.0",
    "phpunit/phpunit": "^11.5 || ^12.1",
    "polishsymfonycommunity/symfony-mocker-container": "^v1.0.8",
    "rector/rector": "^2.0.10",
    "sylius-labs/coding-standard": "^v4.4.0",
    "sylius-labs/suite-tags-extension": "^0.2.0",
    "sylius/sylius-rector": "^v3.0.0",
    "symfony/browser-kit": "^7.4",
    "symfony/config": "^7.4",
    "symfony/debug-bundle": "^7.4",
    "symfony/dependency-injection": "^7.4",
    "symfony/doctrine-bridge": "^7.4",
    "symfony/doctrine-messenger": "^7.4",
    "symfony/dotenv": "^7.4",
    "symfony/filesystem": "^7.4",
    "symfony/flex": "^2.4",
    "symfony/framework-bundle": "^7.4",
    "symfony/http-client": "^7.4",
    "symfony/http-foundation": "^7.4",
    "symfony/http-kernel": "^7.4",
    "symfony/intl": "^7.4",
    "symfony/maker-bundle": "^1.61",
    "symfony/messenger": "^7.4",
    "symfony/property-info": "^7.4",
    "symfony/var-dumper": "^7.4",
    "symfony/var-exporter": "^7.4",
    "symfony/web-profiler-bundle": "^7.4",
    "symfony/webpack-encore-bundle": "^2.2",
    "symplify/easy-coding-standard": "^12.0"
  },
  "conflict": {
    "api-platform/core": "<2.7.13",
    "api-platform/doctrine-common": "<4.2.0",
    "api-platform/json-schema": "<4.2.0",
    "api-platform/metadata": "<4.2.0",
    "api-platform/state": "<4.2.0",
    "api-platform/symfony": "<v4.1.0",
    "babdev/pagerfanta-bundle": "<3.7.0",
    "behat/gherkin": "4.16.*",
    "doctrine/annotations": "<1.13.2",
    "doctrine/collections": "<1.7.0",
    "doctrine/data-fixtures": "<1.7.0",
    "doctrine/dbal": "<3.10.0",
    "doctrine/doctrine-bundle": "<2.18",
    "doctrine/orm": "<3.4",
    "fakerphp/faker": "<1.21.0",
    "friendsofsymfony/rest-bundle": "<3.1.0",
    "jms/serializer-bundle": "<4.2.0",
    "masterminds/html5": "<2.7.5",
    "knplabs/knp-menu": "<3.3.0",
    "knplabs/knp-menu-bundle": "<3.4.1",
    "lexik/jwt-authentication-bundle": "<2.12",
    "payum/core": "<1.7.3",
    "polishsymfonycommunity/symfony-mocker-container": "<1.0.6",
    "sylius/grid-bundle": "<1.11.0",
    "sylius/sylius": "<2.0.6",
    "sylius/resource-bundle": "<1.14",
    "symfony/asset": "<7.0",
    "symfony/cache": "<7.0",
    "symfony/clock": "<7.0",
    "symfony/css-selector": "<4.4.24",
    "symfony/dom-crawler": "<5.4.0",
    "symfony/error-handler": "8.0.*",
    "symfony/expression-language": "<7.0",
    "symfony/finder": "<7.0",
    "symfony/framework-bundle": "8.0.*",
    "symfony/mailer": "<7.0",
    "symfony/mime": "<5.4.0",
    "symfony/monolog-bridge": "<7.0",
    "symfony/password-hasher": "<7.0",
    "symfony/process": "<7.0",
    "symfony/property-access": "<7.0",
    "symfony/stopwatch": "<7.0",
    "symfony/twig-bridge": "<7.0",
    "symfony/uid": "<7.0",
    "symfony/var-dumper": "<5.4.0",
    "symfony/var-exporter": "8.0.*",
    "symfony/web-link": "<5.3.0",
    "symfony/yaml": "<7.0",
    "symplify/easy-coding-standard": "<10.3.0",
    "twig/twig": "<2.14.7",
    "webmozart/assert": "<1.11.0",
    "willdurand/negotiation": "<3.0"
  },
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "ThreeBRS\\SyliusMailChimpPlugin\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\ThreeBRS\\SyliusMailChimpPlugin\\": "tests/Application/src/",
      "Mocks\\ThreeBRS\\SyliusMailChimpPlugin\\": "tests/Mocks/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": false,
      "phpstan/extension-installer": true,
      "symfony/flex": false,
      "php-http/discovery": true,
      "rector/extension-installer": true
    }
  },
  "scripts": {
    "post-install-cmd": [
      "php bin/create_node_symlink.php"
    ],
    "post-update-cmd": [
      "php bin/create_node_symlink.php"
    ],
    "post-create-project-cmd": [
      "php bin/create_node_symlink.php"
    ],
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd",
      "COMPOSER_AUDIT_ABANDONED=ignore composer audit": "script"
    }
  }
}
